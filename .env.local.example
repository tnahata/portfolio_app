# Schwab API Credentials
# Get these from: https://developer.schwab.com/
SCHWAB_APP_KEY=your_schwab_app_key_here
SCHWAB_APP_SECRET=your_schwab_app_secret_here
SCHWAB_REFRESH_TOKEN=your_schwab_refresh_token_here
NEXT_PUBLIC_SCHWAB_APP_KEY=your_schwab_app_key_here

# Coinbase API Credentials
# Get these from: Coinbase Developer Platform (https://portal.cdp.coinbase.com/)
# Note: Use CDP (Developer Platform) API keys, NOT legacy Coinbase API v2 keys
COINBASE_API_KEY=organizations/your-org-id/apiKeys/your-key-id
COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nYour-Private-Key-Here\n-----END EC PRIVATE KEY-----\n

# Control which data sources to use (set to 'true' for mock data, 'false' for real API)
# You can mix and match - e.g., use real Coinbase with mock Schwab
USE_MOCK_SCHWAB=true
USE_MOCK_COINBASE=true
