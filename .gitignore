# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files - IMPORTANT: Never commit these!
.env
.env*.local
.env.development
.env.production
.env.test

# API credentials and sensitive files
cdp_api_key.json
*_api_key.json
*.key
*.secret

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Temporary files
tmp/
temp/
*.tmp

# Lock files (optional - some teams commit these, some don't)
# Uncomment if you want to ignore lock files:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
